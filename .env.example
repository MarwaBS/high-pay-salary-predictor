# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# The .env file is git-ignored and should NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   docker compose --env-file .env up
# ─────────────────────────────────────────────────────────────────────────────

# ── API CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# Use "*" for development (open). Restrict to explicit domains in production.
#
# Development:
CORS_ORIGINS=*
#
# Production example:
# CORS_ORIGINS=https://myapp.com,https://staging.myapp.com

# ── Service Ports ─────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_PORT=8000
MLFLOW_PORT=5000

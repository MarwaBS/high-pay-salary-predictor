# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# The .env file is git-ignored and should NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   docker compose --env-file .env up
# ─────────────────────────────────────────────────────────────────────────────

# ── API CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# Default: empty (rejects cross-origin requests). Set to "*" for local dev.
#
# Development:
CORS_ORIGINS=*
#
# Production example:
# CORS_ORIGINS=https://myapp.com,https://staging.myapp.com

# ── API Authentication ───────────────────────────────────────────────────────
# If set, all /predict requests require an X-API-Key header.
# Unset = dev mode (no auth required).
# API_KEY=your-secret-key-here

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Per-IP rate limit for the /predict endpoint.
# Format: "N/period" where period is second, minute, hour, or day.
RATE_LIMIT=60/minute

# ── Service Ports ─────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_PORT=8000
MLFLOW_PORT=5000
